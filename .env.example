# Xion — operator environment template (Phase 5g-i.1).
#
# Copy to `.env` at the repo root and fill in secrets. The real `.env` is
# gitignored (see `.gitignore`); this file is committed as a template.
#
# Full doctrine for these knobs lives in:
#   - docs/26-INFERENCE-POLICY.md  (policy modes, Genesis Defaults, boot sequence)
#   - docs/04-ARCHITECTURE.md      (§ The Chat Surface (Phase 5g-i))
#   - docs/27-RESEARCH-SPEND.md    (outbound payment rail for the Auto-Research loop)
#   - genesis/INVARIANTS.md § 17   (why the floor exists at all)
#
# The runtime loads this file with a tiny stdlib parser at FastAPI lifespan
# startup. No `python-dotenv` dependency. Already-set environment variables
# win over this file (intentional: CI / systemd / Docker can override).

# ----- Inference Router policy -----
# Valid values: "hosted_api_first" (Genesis Default), "open_weights_only"
# (Invariant 17 clause 5 cutover / annual dry-run mode).
XION_INFERENCE_POLICY=hosted_api_first

# Per-turn generation deadline in seconds (bounds the worst-case connection
# hold in the non-streaming Phase 5g-i surface). Closes with Phase 5g-ii.
XION_CHAT_DEADLINE_S=30

# ----- Hosted turn-serving provider (OpenRouter gateway) -----
# The `OpenRouterGenerativeProvider` only registers if XION_OPENROUTER_API_KEY
# is set. Leave unset to run floor-only (slower, but zero third-party dependency).
#
# OpenRouter is a vendor-of-vendors: it routes requests to upstream model
# providers (Moonshot, Anthropic, OpenAI, Google, Meta-via-partners, ...) under
# one OpenAI-compatible API and one credential. See docs/26-INFERENCE-POLICY.md
# § "Gateway vs direct" for the honest trust-surface accounting.
XION_OPENROUTER_API_KEY=
XION_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Model slugs follow OpenRouter's "provider/model" convention. Genesis Default:
# moonshotai/kimi-k2. One-env-var rotation examples:
#   XION_OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
#   XION_OPENROUTER_MODEL=openai/gpt-4o-mini
#   XION_OPENROUTER_MODEL=google/gemini-2.0-flash-001
XION_OPENROUTER_MODEL=moonshotai/kimi-k2
# Optional-but-recommended app-identity headers. They do NOT authenticate the
# request; they let OpenRouter attribute traffic for developer-portal analytics.
# Misconfiguring them is not a secret-exposure incident.
XION_OPENROUTER_REFERER=
XION_OPENROUTER_APP_NAME=xion-os

# ----- Open-weights floor provider (Ollama / Gemma) -----
# Required for /chat to serve under Invariant 17. If unreachable at startup,
# /chat registers a 503-always handler and other HTTP endpoints keep working.
XION_OLLAMA_URL=http://localhost:11434
XION_OLLAMA_FLOOR_MODEL=gemma3:4b

# ----- API admission control (Phase 5g-iv: bearer auth + rate-limit + TLS) -----
#
# Doctrine for these knobs lives in:
#   - docs/30-API-ADMISSION.md     (operator workflow: token issuance, TLS, rate-limit tuning)
#   - docs/04-ARCHITECTURE.md      (§ The Admission-Control Surface (Phase 5g-iv))
#   - KNOWN_WEAKNESSES.md          (KW-AUTH-001, KW-RATE-001, KW-TLS-001 residuals)
#
# The admission gate runs BEFORE the 5g-iii billing commitment gate. Order of
# rejection on /chat: 401 (missing/invalid Bearer) -> 429 (per-principal bucket
# exceeded) -> 402 (missing/invalid X-Payment-Commitment) -> 451/503/200.

# Template default is the local-development backward-compat posture (mirrors
# the XION_BILLING_REQUIRED=false posture in 5g-iii's template defaults). For
# any production deployment, set this to "true" AND populate XION_API_BEARER_TOKENS
# below. Note: XION_API_HOST != 127.0.0.1 is rejected at startup unless TLS
# cert/key paths are also set (the AdmissionConfig __post_init__ enforces this
# fail-closed regardless of REQUIRE_BEARER mode), so a forgotten bearer flip on
# a non-loopback bind never silently becomes a plaintext-secret incident.
XION_API_REQUIRE_BEARER=false

# Comma-separated principal_id:hex_secret pairs. Each secret hex-decodes to at
# least 16 bytes (>=128 bits of entropy). principal_id matches ^[a-z0-9_-]{1,64}$.
# Generate a secret with: python -c "import secrets; print(secrets.token_hex(32))"
# Example (do NOT commit real tokens; this is a template):
#   XION_API_BEARER_TOKENS=ops:<64hex>,witness-eve:<64hex>,integrator-acme:<64hex>
XION_API_BEARER_TOKENS=

# Per-principal sliding-window rate-limit. The bucket is keyed on the matched
# principal_id (NOT the source IP). Window is true-sliding (deque of monotonic
# timestamps, evict on touch); a principal cannot game the window boundary.
XION_API_RATE_BUDGET=60
XION_API_RATE_WINDOW_S=60

# Per-IP /health bucket. /health is unauthenticated by industry convention so
# liveness probes work; this bucket bounds hostile scraping cadence. Same
# window length as the per-principal bucket.
XION_API_HEALTH_RATE_BUDGET=600

# Bind host and port for the orchestrator/api/__main__.py launcher. Default
# 127.0.0.1 binds loopback only (recommended; front with a reverse proxy that
# handles TLS, ALPN, OCSP, automated cert renewal). A non-loopback host
# REQUIRES both XION_TLS_CERT_PATH and XION_TLS_KEY_PATH below; the launcher
# refuses to start otherwise (fail-closed; mirrors BillingConfig posture).
XION_API_HOST=127.0.0.1
XION_API_PORT=8000

# TLS cert/key paths for uvicorn-native TLS (Posture B in docs/30-API-ADMISSION.md).
# Required iff XION_API_HOST != 127.0.0.1. Operator-managed cert rotation; the
# orchestrator reads these once at process start.
XION_TLS_CERT_PATH=
XION_TLS_KEY_PATH=
