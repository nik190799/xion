# Xion — operator environment template (Phase 5g-i.1).
#
# Copy to `.env` at the repo root and fill in secrets. The real `.env` is
# gitignored (see `.gitignore`); this file is committed as a template.
#
# Full doctrine for these knobs lives in:
#   - docs/26-INFERENCE-POLICY.md  (policy modes, Genesis Defaults, boot sequence)
#   - docs/04-ARCHITECTURE.md      (§ The Chat Surface (Phase 5g-i))
#   - docs/27-RESEARCH-SPEND.md    (outbound payment rail for the Auto-Research loop)
#   - genesis/INVARIANTS.md § 17   (why the floor exists at all)
#
# The runtime loads this file with a tiny stdlib parser at FastAPI lifespan
# startup. No `python-dotenv` dependency. Already-set environment variables
# win over this file (intentional: CI / systemd / Docker can override).

# ----- Inference Router policy -----
# Runtime posture. Valid values:
#   local_only  - default local development posture
#   sovereign   - refuse centralized SaaS providers and require quorum-shaped
#                 gateway configuration when those surfaces are configured
XION_PROFILE=local_only

# Valid values: "hosted_api_first" (Genesis Default), "open_weights_only"
# (Invariant 17 clause 5 cutover / annual dry-run mode).
XION_INFERENCE_POLICY=hosted_api_first

# Per-turn generation deadline in seconds (bounds the worst-case connection
# hold in the non-streaming Phase 5g-i surface). Closes with Phase 5g-ii.
XION_CHAT_DEADLINE_S=30

# ----- Hosted turn-serving provider (Chutes / Bittensor SN64) -----
# The `ChutesGenerativeProvider` registers first when XION_CHUTES_API_KEY
# is set. Leave unset to run the parity fallback / floor-only posture.
#
# Chutes exposes an OpenAI-compatible API on top of Bittensor Subnet 64.
# Phase 6.9 makes this the Genesis Default hosted provider because Xion can
# settle inference credits with on-chain TAO and because TEE variants let
# Xion claim that hosted miners cannot see plaintext prompts/responses.
XION_CHUTES_API_KEY=
XION_CHUTES_BASE_URL=https://llm.chutes.ai/v1
XION_CHUTES_API_BASE_URL=https://api.chutes.ai
XION_CHUTES_HOSTED_MODEL=moonshotai/Kimi-K2.6-TEE
XION_CHUTES_TEE_REQUIRED=true
XION_CHUTES_SHADOW_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507
XION_CHUTES_BILLING_LEDGER=ledgers/BILLING_LEDGER.jsonl
XION_SHADOW_LEDGER=ledgers/SHADOW_LEDGER.jsonl
XION_CHUTES_CREDIT_FLOOR_USD=5.00
XION_CHUTES_BILLING_MAX_STALENESS_S=900

# ----- Embeddings / memory retrieval (Phase 6.9) -----
XION_CHUTES_EMBED_MODEL=Qwen/Qwen3-Embedding-8B
XION_LOCAL_EMBED_MODEL=BAAI/bge-m3
XION_EMBED_DIMENSIONS=384
XION_MEMORY_VECTOR_DB=journal_vectors.db
XION_JOURNAL_EMBEDDINGS=true
XION_CHUTES_RERANK_MODEL=BAAI/bge-reranker-v2-m3
XION_LOCAL_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ----- Open-weights floor provider (Ollama / Gemma) -----
# Required for /chat to serve under Invariant 17. If unreachable at startup,
# /chat registers a 503-always handler and other HTTP endpoints keep working.
#
# Genesis Default floor model (Phase 5g-viii): gemma4:e4b-it-q4_K_M
# (rotated 2026-04-23 from the Phase 5g-i pin gemma3:4b; see
# docs/26-INFERENCE-POLICY.md § "The floor-model choice (Gemma 4 E4B-it)"
# for the rotation record and the C0 probe trail). The rotation is one
# env-var; rollback to the prior pin is also one env-var:
#   XION_OLLAMA_FLOOR_MODEL=gemma3:4b
# First-time pull: `ollama pull gemma4:e4b-it-q4_K_M` (~9.6 GB, multimodal
# bundled tag from the Ollama library; ~9–10 GB RAM at runtime).
#
# Local D2 development uses http://localhost:11434. Akash production-style
# deployments should set this to the in-deployment sidecar:
#   XION_OLLAMA_URL=http://xion-ollama:11434
# A laptop-local daemon does not satisfy the deployed-floor closure bar for
# KW-FLOOR-DEPLOY-001.
XION_OLLAMA_URL=http://localhost:11434
XION_OLLAMA_FLOOR_MODEL=gemma4:e4b-it-q4_K_M

# ----- Mainnet read quorum (sovereign profile) -----
# Comma-separated Base RPC endpoints. Sovereign mode requires at least three
# when this surface is configured; the quorum reader accepts only majority-
# matching responses.
XION_BASE_RPC_URLS=

# Comma-separated Arweave gateways. Sovereign mode requires at least two when
# this surface is configured; xion-verify gateway checks require agreement.
XION_ARWEAVE_GATEWAYS=

# Optional: absolute path to the upstream Hugging Face GGUF the
# open_weights_manifest.json model-blob entry pins. Setting this enables
# `xion-verify inference-sovereignty` to byte-verify the floor model
# (entry id "gemma4-e4b-it-q4-k-m-gguf"). Leaving it unset is supported:
# the verifier reports NOT_YET_SEALED for that entry only and the rest
# of the floor verifies normally; runtime behavior is unchanged.
#
# First-time setup (download once + sha256-check) is documented in
# docs/13-OPERATIONS.md § "First-time GGUF setup". The pinned upstream
# is ggml-org/gemma-4-E4B-it-GGUF Q4_K_M (~5.0 GB on disk, ~6 GB RAM at
# runtime); operators with tight RAM headroom can use this smaller
# text-only build instead of the multimodal-bundled Ollama-library tag.
XION_OPEN_WEIGHTS_GGUF_PATH=

# ----- API admission control (Phase 5g-iv: bearer auth + rate-limit + TLS) -----
#
# Doctrine for these knobs lives in:
#   - docs/30-API-ADMISSION.md     (operator workflow: token issuance, TLS, rate-limit tuning)
#   - docs/04-ARCHITECTURE.md      (§ The Admission-Control Surface (Phase 5g-iv))
#   - KNOWN_WEAKNESSES.md          (KW-AUTH-001, KW-RATE-001, KW-TLS-001 residuals)
#
# The admission gate runs BEFORE the 5g-iii billing commitment gate. Order of
# rejection on /chat: 401 (missing/invalid Bearer) -> 429 (per-principal bucket
# exceeded) -> 402 (missing/invalid X-Payment-Commitment) -> 451/503/200.

# Template default is the local-development backward-compat posture (mirrors
# the XION_BILLING_REQUIRED=false posture in 5g-iii's template defaults). For
# any production deployment, set this to "true" AND populate XION_API_BEARER_TOKENS
# below. Note: XION_API_HOST != 127.0.0.1 is rejected at startup unless TLS
# cert/key paths are also set (the AdmissionConfig __post_init__ enforces this
# fail-closed regardless of REQUIRE_BEARER mode), so a forgotten bearer flip on
# a non-loopback bind never silently becomes a plaintext-secret incident.
XION_API_REQUIRE_BEARER=false

# Comma-separated principal_id:hex_secret pairs. Each secret hex-decodes to at
# least 16 bytes (>=128 bits of entropy). principal_id matches ^[a-z0-9_-]{1,64}$.
# Generate a secret with: python -c "import secrets; print(secrets.token_hex(32))"
# Example (do NOT commit real tokens; this is a template):
#   XION_API_BEARER_TOKENS=ops:<64hex>,witness-eve:<64hex>,integrator-acme:<64hex>
XION_API_BEARER_TOKENS=

# Per-principal sliding-window rate-limit. The bucket is keyed on the matched
# principal_id (NOT the source IP). Window is true-sliding (deque of monotonic
# timestamps, evict on touch); a principal cannot game the window boundary.
XION_API_RATE_BUDGET=60
XION_API_RATE_WINDOW_S=60

# Per-IP /health bucket. /health is unauthenticated by industry convention so
# liveness probes work; this bucket bounds hostile scraping cadence. Same
# window length as the per-principal bucket.
XION_API_HEALTH_RATE_BUDGET=600

# Bind host and port for the orchestrator/api/__main__.py launcher. Default
# 127.0.0.1 binds loopback only (recommended; front with a reverse proxy that
# handles TLS, ALPN, OCSP, automated cert renewal). A non-loopback host
# REQUIRES both XION_TLS_CERT_PATH and XION_TLS_KEY_PATH below; the launcher
# refuses to start otherwise (fail-closed; mirrors BillingConfig posture).
XION_API_HOST=127.0.0.1
XION_API_PORT=8000

# TLS cert/key paths for uvicorn-native TLS (Posture B in docs/30-API-ADMISSION.md).
# Required iff XION_API_HOST != 127.0.0.1. Operator-managed cert rotation; the
# orchestrator reads these once at process start.
XION_TLS_CERT_PATH=
XION_TLS_KEY_PATH=

# ─────────────────────────────────────────────────────────────────────────────
# Web client (Phase 5g-v)
# ─────────────────────────────────────────────────────────────────────────────
# The web client is the operator's own dashboard against the admission-gated
# HTTP surface. It is opt-in: XION_WEB_CLIENT_ENABLED defaults to "false" and
# the orchestrator does not mount /app/* or serve index.html at / when the flag
# is off. Flipping it on REQUIRES XION_WEB_CLIENT_DIST_PATH to point at a
# readable directory containing an index.html (typically produced by
# `cd clients/web && npm ci && npm run build` landing at clients/web/dist/).
#
# Fail-closed: if enabled but the path is missing / unreadable / without an
# index.html, the lifespan refuses to boot (mirrors BillingConfig and
# AdmissionConfig posture). An operator who does not want the web surface
# leaves this at "false" and incurs zero additional surface area from 5g-v.
#
# See docs/31-WEB-CLIENT.md for the full operator runbook.
XION_WEB_CLIENT_ENABLED=false

# Absolute or repo-relative path to the built SPA bundle directory. Must
# contain at least index.html. Default matches the in-repo `npm run build`
# output location; operators shipping the bundle from elsewhere (e.g. a
# per-deploy artifact store) point this at the absolute path on the host.
XION_WEB_CLIENT_DIST_PATH=clients/web/dist

# ─────────────────────────────────────────────────────────────────────────────
# Multi-worker coherence (Phase 5g+)
# ─────────────────────────────────────────────────────────────────────────────
# The orchestrator defaults to the single-worker posture (XION_API_WORKERS=1).
# Running multiple uvicorn workers without a shared-state broker is the
# documented corruption path (KW-API-002: each worker constructs its own
# Supervisor and writes tick_commit rows under different relay_ids to the
# same SENSORIUM_LEDGER; KW-RATE-001: each worker holds its own in-process
# rate-limit bucket, so the effective per-principal budget is N × configured).
# The launcher refuses to start when XION_API_WORKERS > 1 unless
# XION_BROKER_DB_PATH is also set.
#
# When XION_BROKER_DB_PATH is set, the orchestrator opens a SQLite-WAL broker
# file at that path and uses it for:
#   - Supervisor single-leader election (exactly one worker ticks; followers
#     read the leader's published snapshot for /drive and /sensorium).
#   - Per-principal rate-limit bucket coherence across all N workers.
#
# The broker file lives on the orchestrator's trusted filesystem (there is no
# broker-side authn; a malicious operator with write access to this path can
# already corrupt every ledger). One file to back up; inspect at 3am with
# `sqlite3 <path>` for the three tables: supervisor_snapshot, supervisor_leader,
# rate_limit_events. See docs/33-MULTI-WORKER.md for the full doctrine +
# operator runbook.
#
# Defaults:
#   XION_API_WORKERS=1                 (single-worker posture; broker unused)
#   XION_BROKER_DB_PATH=               (unset; disables the broker entirely)
#
# Production multi-worker example (uncomment and edit):
#   XION_API_WORKERS=2
#   XION_BROKER_DB_PATH=/var/lib/xion/broker.sqlite3
XION_API_WORKERS=1
XION_BROKER_DB_PATH=

# ─────────────────────────────────────────────────────────────────────────────
# AO Core gateway (Phase 6.1 / Phase 6.1.b)
# ─────────────────────────────────────────────────────────────────────────────
# `xion-verify ao-handlers` reads this when it has a non-placeholder
# `genesis/AO_DEPLOY_RECEIPT.json` and needs to confirm tip parity against the
# Compute Unit. Two doctrine-permissible substrates exist at Phase 6.1 (see
# `docs/28-AO-CORE.md` § "Substrate amendment (Phase 6.1.b, 2026-04-24)" and
# `KNOWN_WEAKNESSES.md` `KW-AOCORE-004` for the election rationale):
#
#   1. Upstream legacynet (default; currently impaired — MU returns HTTP 500):
#        XION_AO_GATEWAY_URL=https://cu.ao-testnet.xyz
#      Receipt's `substrate` field MUST be `legacynet`. Runbook:
#        docs/runbooks/AO_DEPLOY_WSL2.md
#
#   2. Local `permaweb/ao-localnet` Docker stack (elected 2026-04-24,
#      Phase 6.1.b — self-sufficient, CI-able, no upstream dependency):
#        XION_AO_GATEWAY_URL=http://localhost:4004
#      Receipt's `substrate` field MUST be `localnet`. Runbook + bring-up:
#        docs/runbooks/AO_DEPLOY_LOCALNET.md
#        scripts/ao-localnet-up.sh
#        infra/ao-localnet/README.md
#
# Mainnet (`https://push.forward.computer`) is FORBIDDEN at Phase 6.1; the
# verifier rejects any receipt declaring `substrate: "mainnet"` outright per
# the Tier-3 cosign ceremony obligation in `docs/09-GOVERNANCE.md`. That gate
# is structural, not a config knob.
#
# For the localnet AO Core receipt, set this to the CU base
# (`http://localhost:4004`) before running `xion-verify ao-handlers` or
# `xion-verify interaction-anchor`; both verifiers use `/dry-run`.
# When unset, the verifier falls back to its built-in legacynet default
# (`https://cu.ao-testnet.xyz`).
XION_AO_GATEWAY_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Interaction Anchor daemon (Phase 6.3)
# ─────────────────────────────────────────────────────────────────────────────
# Hourly Merkle-root daemon configuration. See `docs/04-ARCHITECTURE.md`
# § "Anchor Daemon (Phase 6.3)" for the doctrine; the daemon is a no-op when
# the source ledgers are empty and is safe to leave running.
XION_ANCHOR_DB_PATH=ledgers/ANCHOR_LEDGER.jsonl
XION_ANCHOR_TICK_INTERVAL_SECONDS=3600

# Phase 6.3.b: AO Core sink configuration.
# Valid values: "local" (default), "ao_core"
# When "ao_core", the daemon posts anchors to the AO Core process through
# scripts/ao-send-anchor-batch.cjs and records the returned AO message id in
# ANCHOR_LEDGER; `xion-verify interaction-anchor` then confirms the batch root
# exists on the AO process when XION_AO_GATEWAY_URL points at the matching CU.
XION_ANCHOR_SINK=local
XION_AO_PROCESS_ID=
XION_AO_SIGNER_JWK_PATH=

# ─────────────────────────────────────────────────────────────────────────────
# Pricing and Modality Costs (Phase 6.4)
# ─────────────────────────────────────────────────────────────────────────────
# Baseline chat cost is defined by XION_POSTED_PRICE_MICRO_XION (default 1000).
# The modalities add flat micro-XION costs per message.
# Genesis Defaults are 0 until Phase 6.5.
XION_MODALITY_COST_VISUAL=0
XION_MODALITY_COST_VITALS=0
XION_MODALITY_COST_VOICE=0
